# ──────────────────────────────────────────────
#  EICTA Digital Credentials Portal — .gitignore
# ──────────────────────────────────────────────

# ── Environment / Secrets ─────────────────────
# Never commit real credentials. Use .env.example instead.
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ── Node modules ──────────────────────────────
node_modules/
client/node_modules/
server/node_modules/

# ── Build output ──────────────────────────────
client/dist/
client/build/

# ── Generated certificate PDFs ────────────────
# Default output of: node generateCertificate.mjs
certificate.pdf
*.generated.pdf

# ── Documentation / generated guides ──────────
EICTA_Developer_Guidebook.pdf
EICTA_CEO_Demo_Document.pdf
generate_guidebook.py
generate_pdf.py
generate_ceo_demo.py

# ── Logs ──────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS files ──────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Misc ──────────────────────────────────────
.cache/
.parcel-cache/
coverage/
