# ──────────────────────────────────────────────────────────────
#  server/.env.example
#
#  Copy this file to  server/.env  and fill in your real values.
#  NEVER commit  server/.env  — it is listed in  .gitignore.
# ──────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
PORT=5000

# ── MySQL Database ────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_root_password
DB_NAME=auth_db

# ── JWT ───────────────────────────────────────────────────────
# Use a long, random string — never share this value.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ── Email (Gmail SMTP) ────────────────────────────────────────
# EMAIL_USER : your Gmail address
# EMAIL_PASS : a 16-character App Password (NOT your login password)
#   How to get one:
#     myaccount.google.com → Security → 2-Step Verification → App passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_16_character_app_password

# ── App ───────────────────────────────────────────────────────
# URL of the React dev server (used for CORS)
CLIENT_URL=http://localhost:3000
